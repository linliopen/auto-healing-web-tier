aws_region        = "us-east-1"
project_name      = "auto-healing-web"
environment       = "dev"
vpc_cidr          = "10.0.0.0/16"
availability_zones = ["us-east-1a", "us-east-1b"]
public_subnet_cidrs = ["10.0.1.0/24", "10.0.2.0/24"]
instance_type     = "t3.micro"
asg_min_size      = 2
asg_max_size      = 4
asg_desired_capacity = 2
# Update this with your actual GitHub Container Registry image
# container_image   = "ghcr.io/YOUR_GH_USERNAME/auto-healing-web-nginx:latest"
